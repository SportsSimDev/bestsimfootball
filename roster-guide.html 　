import React, { useState, useEffect } from 'react';
import Papa from 'papaparse';
import { mapExternalRosterToInternal } from './rosterParser';
import { saveAFCustomTeams, migrateAFTeams } from './storage';
import { LongPressable, getLang } from './App';

// --- アメフト用 神エディット＆共有画面 ---
export const AFEditScreen = ({ teams, setTeams, onBack, tutorialStep, completeTutorialStep }) => {
  const [teamIdx, setTeamIdx] = useState(0);
  const [playerIdx, setPlayerIdx] = useState(0);
  const [confirmModal, setConfirmModal] = useState(null);
  const [alertMessage, setAlertMessage] = useState('');
  const [exportFormat, setExportFormat] = useState('txt');
  const [selectedLeagueType, setSelectedLeagueType] = useState('Normal');
  const [isMobile, setIsMobile] = useState(window.innerWidth < 768);
  const [hasUnsavedChanges, setHasUnsavedChanges] = useState(false);
  const lang = getLang();
  const isJa = lang === 'ja';
  const isEs = lang === 'es';
  const tTextEdit = (ja, es, en) => isJa ? ja : (isEs ? es : en);
  const [editTab, setEditTab] = useState('edit'); // 'build' | 'edit'
  const [importText, setImportText] = useState('');
  const [showImportHelp, setShowImportHelp] = useState(false);

  useEffect(() => {
    if (tutorialStep === 0) {
      completeTutorialStep(0);
      setEditTab('build'); // 初期はBUILDタブを強制
    }
  }, [tutorialStep, completeTutorialStep]);

  useEffect(() => {
    const handleResize = () => setIsMobile(window.innerWidth < 768);
    window.addEventListener('resize', handleResize);
    return () => window.removeEventListener('resize', handleResize);
  }, []);

  const team = teams[teamIdx] || teams[0];
  const player = playerIdx === -1 ? null : (team?.lineup[playerIdx] || team?.lineup[0]);

  const handleExport = async (teamsData, format) => {
    try {
      let dataStr = '';
      let mimeType = 'text/plain';
      
      if (format === 'json') {
        dataStr = JSON.stringify(teamsData, null, 2);
        mimeType = 'application/json';
      } else if (format === 'txt') {
        let txt = "================================================================================\n";
        txt += " Best Sim Football - Roster Data Report\n";
        txt += "================================================================================\n\n";
        teamsData.forEach(t => {
          txt += `Team: ${t.name} (${t.initial})\n`;
          txt += `Conference: ${t.league} / Division: ${t.division}\n`;
          txt += `Head Coach: ${t.manager.name} (IN: ${t.manager.inside_run}, OUT: ${t.manager.outside_run}, SP: ${t.manager.short_pass}, DP: ${t.manager.deep_pass}, AGG: ${t.manager.def_aggressiveness})\n`;
          txt += `--------------------------------------------------------------------------------\n`;
          txt += `Pos | Name                 | SPD STR AGI AWR ACC POW CTH RTE SEC BLK RSH TKL COV\n`;
          txt += `--------------------------------------------------------------------------------\n`;
          t.lineup.forEach(p => {
            const s = p.af_stats || {};
            const pad = (str, len) => String(str).padEnd(len, ' ');
            const padNum = (num) => String(num || 0).padStart(3, ' ');
            txt += `${pad(s.position, 3)} | ${pad(p.name, 20)} | ${padNum(s.speed)} ${padNum(s.strength)} ${padNum(s.agility)} ${padNum(s.awareness)} ${padNum(s.passAccuracy)} ${padNum(s.passPower)} ${padNum(s.catch)} ${padNum(s.routeRunning)} ${padNum(s.ballSecurity)} ${padNum(s.blocking)} ${padNum(s.passRush)} ${padNum(s.tackling)} ${padNum(s.coverage)}\n`;
          });
          txt += `================================================================================\n\n`;
        });
        dataStr = txt;
        mimeType = 'text/plain';
      } else if (format === 'csv') {
        let csv = "Team,Initial,Conf,Div,Type,Name,Pos,Speed_InsideRun,Strength_OutsideRun,Agility_ShortPass,Awareness_DeepPass,PassAcc_DefAgg,PassPow,Catch,Route,BallSec,Block,Rush,Tackle,Cov\n";
        teamsData.forEach(t => {
          csv += `"${t.name}","${t.initial}","${t.league}","${t.division}","Manager","${t.manager.name}","HC",${t.manager.inside_run},${t.manager.outside_run},${t.manager.short_pass},${t.manager.deep_pass},${t.manager.def_aggressiveness || 50},0,0,0,0,0,0,0,0\n`;
          t.lineup.forEach(p => {
            const s = p.af_stats || {};
            csv += `"${t.name}","${t.initial}","${t.league}","${t.division}","Player","${p.name}","${s.position}",${s.speed||0},${s.strength||0},${s.agility||0},${s.awareness||0},${s.passAccuracy||0},${s.passPower||0},${s.catch||0},${s.routeRunning||0},${s.ballSecurity||0},${s.blocking||0},${s.passRush||0},${s.tackling||0},${s.coverage||0}\n`;
          });
        });
        dataStr = csv;
        mimeType = 'text/csv';
      }

      const blob = new Blob([dataStr], { type: mimeType });
      const filename = `afsim_custom_roster.${format}`;
      const file = new File([blob], filename, { type: mimeType });

      if (navigator.canShare && navigator.canShare({ files: [file] })) {
        try {
          await navigator.share({
            title: 'Best Sim Football Roster',
            files: [file]
          });
          return;
        } catch (err) {
          console.warn('Share cancelled or failed', err);
          if (err.name === 'AbortError') return;
        }
      }

      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      link.download = filename;
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      URL.revokeObjectURL(url);
    } catch (e) {
      console.error('Export failed:', e);
      setAlertMessage(isJa ? 'エクスポートに失敗しました' : 'Export failed.');
    }
  };

  const processImportedContent = (fileContent, sourceName) => {
    try {
      const nameLower = sourceName.toLowerCase();
      const trimmedContent = fileContent.trim();
      let imported = null;

      const isJson = trimmedContent.startsWith('[') || trimmedContent.startsWith('{');
      const isTxt = nameLower.endsWith('.txt') && !isJson;
      const isCsv = !isJson && !isTxt && (nameLower.endsWith('.csv') || trimmedContent.includes(','));

      if (isJson) {
        imported = JSON.parse(trimmedContent);
      } else if (isCsv) {
        const parsedCsv = Papa.parse(trimmedContent, { header: true, skipEmptyLines: true });
        if (parsedCsv.data && parsedCsv.data.length > 0) {
          const firstRow = parsedCsv.data[0];
          if (firstRow.PFNA !== undefined || firstRow.PGID !== undefined || firstRow.player_name !== undefined || firstRow.gsis_id !== undefined) {
            const players = mapExternalRosterToInternal(parsedCsv.data);
            const teamsMap = {};
            parsedCsv.data.forEach((row, i) => {
              const tgid = row.TGID || row.team || 'FA';
              if (!teamsMap[tgid]) {
                teamsMap[tgid] = {
                  name: tgid === 'FA' ? 'Free Agents' : `Team ${tgid}`, 
                  initial: String(tgid).substring(0, 3).toUpperCase(),
                  league: 'Conf', division: 'Div',
                  color: { home: { main: '#1a5f9a' } },
                  af_stats: { wins: 0, losses: 0, pf: 0, pa: 0 },
                  manager: { name: 'Coach', inside_run: 50, outside_run: 50, short_pass: 50, deep_pass: 50, def_aggressiveness: 50 },
                  lineup: []
                };
              }
              const player = players[i];
              const fullName = player.firstName ? `${player.firstName[0]}.${player.lastName}` : player.lastName;
              teamsMap[tgid].lineup.push({
                name: fullName,
                af_stats: { position: player.position, ...player.attributes, fatigue: player.status.fatigue, condition: player.status.condition }
              });
            });
            imported = Object.values(teamsMap);
          } else if (firstRow.Team !== undefined) {
            const newTeamsMap = {};
            const newTeamsList = [];
            parsedCsv.data.forEach(row => {
              const tName = row.Team;
              if (!tName) return;
              if (!newTeamsMap[tName]) {
                newTeamsMap[tName] = {
                  name: tName, initial: row.Initial, league: row.Conf, division: row.Div,
                  color: { home: { main: '#1a5f9a' } },
                  af_stats: { wins: 0, losses: 0, pf: 0, pa: 0 },
                  manager: { name: 'Coach', inside_run: 50, outside_run: 50, short_pass: 50, deep_pass: 50, def_aggressiveness: 50 },
                  lineup: []
                };
                newTeamsList.push(newTeamsMap[tName]);
              }
              const t = newTeamsMap[tName];
              if (row.Type === 'Manager') {
                t.manager = { name: row.Name, inside_run: parseInt(row.Speed_InsideRun)||50, outside_run: parseInt(row.Strength_OutsideRun)||50, short_pass: parseInt(row.Agility_ShortPass)||50, deep_pass: parseInt(row.Awareness_DeepPass)||50, def_aggressiveness: parseInt(row.PassAcc_DefAgg)||50 };
              } else if (row.Type === 'Player') {
                t.lineup.push({
                  name: row.Name,
                  af_stats: {
                    position: row.Pos, speed: parseInt(row.Speed_InsideRun)||0, strength: parseInt(row.Strength_OutsideRun)||0, agility: parseInt(row.Agility_ShortPass)||0, awareness: parseInt(row.Awareness_DeepPass)||0,
                    passAccuracy: parseInt(row.PassAcc_DefAgg)||0, passPower: parseInt(row.PassPow)||0, catch: parseInt(row.Catch)||0, routeRunning: parseInt(row.Route)||0, ballSecurity: parseInt(row.BallSec)||0, blocking: parseInt(row.Block)||0, passRush: parseInt(row.Rush)||0, tackling: parseInt(row.Tackle)||0, coverage: parseInt(row.Cov)||0
                  }
                });
              }
            });
            imported = newTeamsList;
          }
        }
      } else if (isTxt) {
        const lines = trimmedContent.split('\n');
          const newTeamsList = [];
          let currentTeam = null;
          for (let line of lines) {
            line = line.trim();
            if (!line) continue;
            const teamMatch = line.match(/^Team:\s+(.+?)\s+\((.*?)\)/);
            if (teamMatch) {
              currentTeam = { name: teamMatch[1].trim(), initial: teamMatch[2].trim(), league: '', division: '', color: { home: { main: '#1a5f9a' } }, af_stats: { wins: 0, losses: 0, pf: 0, pa: 0 }, manager: { name: 'Coach', inside_run: 50, outside_run: 50, short_pass: 50, deep_pass: 50, def_aggressiveness: 50 }, lineup: [] };
              newTeamsList.push(currentTeam);
              continue;
            }
            if (currentTeam) {
              const confMatch = line.match(/^Conference:\s+(.+?)\s+\/\s+Division:\s+(.+)/);
              if (confMatch) { currentTeam.league = confMatch[1].trim(); currentTeam.division = confMatch[2].trim(); continue; }
              const hcMatch = line.match(/^Head Coach:\s+(.+?)\s+\(IN:\s+(\d+),\s+OUT:\s+(\d+),\s+SP:\s+(\d+),\s+DP:\s+(\d+),\s+AGG:\s+(\d+)\)/);
              if (hcMatch) { currentTeam.manager = { name: hcMatch[1].trim(), inside_run: parseInt(hcMatch[2],10), outside_run: parseInt(hcMatch[3],10), short_pass: parseInt(hcMatch[4],10), deep_pass: parseInt(hcMatch[5],10), def_aggressiveness: parseInt(hcMatch[6],10) }; continue; }
              const playerMatch = line.match(/^([A-Z0-9]{1,3})\s+\|\s+(.+?)\s+\|\s+(\d+)\s+(\d+)\s+(\d+)\s+(\d+)\s+(\d+)\s+(\d+)\s+(\d+)\s+(\d+)\s+(\d+)\s+(\d+)\s+(\d+)\s+(\d+)/);
              if (playerMatch) {
                currentTeam.lineup.push({
                  name: playerMatch[2].trim(),
                  af_stats: {
                    position: playerMatch[1].trim(), speed: parseInt(playerMatch[3],10), strength: parseInt(playerMatch[4],10), agility: parseInt(playerMatch[5],10), awareness: parseInt(playerMatch[6],10),
                    passAccuracy: parseInt(playerMatch[7],10), passPower: parseInt(playerMatch[8],10), catch: parseInt(playerMatch[9],10), routeRunning: parseInt(playerMatch[10],10),
                    ballSecurity: parseInt(playerMatch[11],10), blocking: parseInt(playerMatch[12],10), passRush: parseInt(playerMatch[13],10), tackling: parseInt(playerMatch[14],10), coverage: parseInt(playerMatch[15],10)
                  }
                });
              }
            }
          }
          imported = newTeamsList;
        }
        if (imported && Array.isArray(imported)) { 
          setTeams(migrateAFTeams(imported)); setHasUnsavedChanges(true);
          setAlertMessage(isJa ? '✅ カスタムロースターを読み込みました！セーブボタンを押して保存してください。' : '✅ Custom roster loaded! Please click SAVE to apply changes.'); 
          setEditTab('edit');
        } else { throw new Error('Invalid format'); }
      } catch (err) {
        console.error('Import failed:', err);
        setAlertMessage(isJa ? `インポートに失敗しました: ${err.message}\nファイル形式やURLを確認してください。` : `Import failed: ${err.message}\nPlease check the file format or URL.`);
      }
  };

  const handleImportFile = (e) => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = (event) => processImportedContent(event.target.result, file.name);
    reader.readAsText(file);
    e.target.value = null;
  };

  const handleImportTextSubmit = () => {
    if (!importText.trim()) return;
    processImportedContent(importText, 'paste.csv');
    setImportText('');
  };

  const handlePaste = async () => {
    try {
      const text = await navigator.clipboard.readText();
      setImportText(text);
    } catch (err) {
      alert(isJa ? 'クリップボードからの読み込みに失敗しました。手動で貼り付けてください。' : 'Failed to read from clipboard. Please paste manually.');
    }
  };

  const updatePlayer = (field, val) => {
    const newTeams = [...teams];
    const p = newTeams[teamIdx].lineup[playerIdx];
    if (field === 'name') p.name = val;
    else if (field === 'position') { if (!p.af_stats) p.af_stats = {}; p.af_stats.position = val; } 
    else {
      if (!p.af_stats) p.af_stats = {};
      const numVal = val === '' ? 0 : parseInt(val, 10);
      p.af_stats[field] = isNaN(numVal) ? 0 : numVal;
    }
    setTeams(newTeams); setHasUnsavedChanges(true);
  };

  const updateTeam = (field, val) => {
    const newTeams = [...teams];
    if (field === 'name') newTeams[teamIdx].name = val;
    else if (field === 'initial') newTeams[teamIdx].initial = val;
    setTeams(newTeams); setHasUnsavedChanges(true);
  };

  const updateTeamColor = (colorHex) => {
    const newTeams = [...teams];
    if (!newTeams[teamIdx].color) newTeams[teamIdx].color = { home: { main: colorHex }, visitor: { main: '#ffffff' } };
    else { if (!newTeams[teamIdx].color.home) newTeams[teamIdx].color.home = {}; newTeams[teamIdx].color.home.main = colorHex; }
    setTeams(newTeams); setHasUnsavedChanges(true);
  };

  const updateManager = (field, val) => {
    const newTeams = [...teams];
    if (!newTeams[teamIdx].manager) newTeams[teamIdx].manager = { name: 'Coach', inside_run: 50, outside_run: 50, short_pass: 50, deep_pass: 50 };
    if (field === 'name') newTeams[teamIdx].manager.name = val;
    else {
      const numVal = val === '' ? 0 : parseInt(val, 10);
      newTeams[teamIdx].manager[field] = isNaN(numVal) ? 0 : numVal;
    }
    setTeams(newTeams); setHasUnsavedChanges(true);
  };

  const handleSave = () => {
    saveAFCustomTeams(teams);
    setHasUnsavedChanges(false);
    if (tutorialStep === 2) {
      completeTutorialStep(2);
      setAlertMessage(isJa ? '✅ チームデータが作成・保存されました！\n「戻る」ボタンからメニューに戻り、試合を始めましょう！' : '✅ Team data created and saved!\nClick BACK to return to the menu and start playing!');
    } else {
      setAlertMessage(isJa ? '✅ エディットデータをローカルに保存しました！' : '✅ Custom Roster saved locally!');
    }
  };

  const handleBack = () => {
    if (hasUnsavedChanges) {
      if (!window.confirm(isJa ? '未保存の変更があります。変更を破棄して戻りますか？' : 'You have unsaved changes. Discard and go back?')) return;
    }
    onBack();
  };

  const generateLeague = (type) => setConfirmModal(type);

  const confirmGenerateLeague = () => {
    const type = confirmModal;
    setConfirmModal(null);
    const count = type === 'Normal' ? 32 : (type === 'NoName' ? 130 : (type === 'Simple3' ? 7 : (type === 'Simple2' ? 9 : 12)));
    const newTeams = [];
    const cities = ["Empire City", "Angel Coast", "Windy City", "Space Port", "Sun Valley", "Liberty", "Alamo", "Ocean View", "Lone Star", "Silicon", "Capital", "Motor City", "Emerald", "Mile High", "Music City", "Steel Town", "Gold Coast", "Bay City", "Rivertown", "Twin Cities", "Desert Springs", "Pine Valley", "Silver State", "Redwood", "Crescent", "Grand Peaks", "Ironville", "Crystal Bay", "Maple Ridge", "Cobalt", "Aurora", "Brimstone"];
    const mascots = ["Rhinos", "Cobras", "Vipers", "Dragons", "Griffins", "Phantoms", "Storm", "Thunder", "Lightning", "Cyclones", "Comets", "Meteors", "Orbiters", "Stars", "Blazers", "Pioneers", "Knights", "Spartans", "Gladiators", "Hunters", "Snipers", "Vanguards", "Sentinels", "Wardens", "Mutants", "Cyborgs", "Mechas", "Monsters", "Gargoyles", "Krakens", "Reapers", "Brawlers"];
    const lastNames = ["Smith", "Johnson", "Williams", "Brown", "Jones", "Garcia", "Miller", "Davis", "Rodriguez", "Martinez", "Hernandez", "Lopez", "Gonzalez", "Wilson", "Anderson", "Thomas", "Taylor", "Moore", "Jackson", "Martin", "Lee", "Perez", "Thompson", "White", "Harris", "Sanchez", "Clark", "Ramirez", "Lewis", "Robinson", "Walker", "Young", "Allen", "King", "Wright", "Scott", "Torres", "Nguyen", "Hill", "Flores", "Green", "Adams", "Nelson", "Baker", "Hall", "Rivera", "Campbell", "Mitchell", "Carter", "Roberts"];
    const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
    const generateName = () => `${letters[Math.floor(Math.random() * letters.length)]}.${lastNames[Math.floor(Math.random() * lastNames.length)]}`;
    const usedTeamNames = new Set();
    const generateTeamName = (isCollege) => {
      let tName = "";
      do {
        const city = cities[Math.floor(Math.random() * cities.length)];
        const mascot = mascots[Math.floor(Math.random() * mascots.length)];
        if (isCollege) { tName = `${city} ${["State", "Univ", "Tech", "College"][Math.floor(Math.random() * 4)]} ${mascot}`; } 
        else { tName = `${city} ${mascot}`; }
      } while (usedTeamNames.has(tName));
      usedTeamNames.add(tName);
      return tName;
    };
    const createTeam = (name, initial, conf, div, i) => ({
      name, initial, league: conf, division: div,
      color: { home: { main: i%2===0 ? '#1a5f9a' : '#9a1a1a' } },
      af_stats: { wins: 0, losses: 0, pf: 0, pa: 0 },
      manager: { name: generateName(), inside_run: 30 + Math.floor(Math.random() * 40), outside_run: 30 + Math.floor(Math.random() * 40), short_pass: 60 + Math.floor(Math.random() * 40), deep_pass: 50 + Math.floor(Math.random() * 40), def_aggressiveness: 30 + Math.floor(Math.random() * 70) },
      // 🏈 ロースターを40人に拡充し、控え選手（ローテーション）を機能させる
      lineup: Array(40).fill(null).map((_, j) => {
        const pos = j<2?'QB':j<5?'RB':j<6?'FB':j<11?'WR':j<14?'TE':j<22?'OL':j<28?'DL':j<33?'LB':j<38?'DB':j===38?'K':'P';
        const rand = (min, max) => min + Math.floor(Math.random() * (max - min + 1));
        const s = { position: pos, speed: rand(50, 80), strength: rand(50, 80), agility: rand(50, 80), awareness: rand(50, 80), passAccuracy: rand(20, 50), passPower: rand(20, 50), catch: rand(30, 60), routeRunning: rand(30, 60), ballSecurity: rand(40, 70), blocking: rand(30, 60), passRush: rand(30, 60), tackling: rand(30, 60), coverage: rand(30, 60), fatigue: 0 };
        if (pos === 'QB') { s.passAccuracy = rand(70, 95); s.passPower = rand(70, 95); s.awareness = rand(70, 95); s.speed = rand(50, 85); s.agility = rand(50, 80); }
        else if (pos === 'RB') { s.speed = rand(80, 95); s.agility = rand(80, 95); s.strength = rand(60, 85); s.ballSecurity = rand(75, 95); s.catch = rand(50, 80); }
        else if (pos === 'FB') { s.strength = rand(75, 95); s.blocking = rand(75, 90); s.speed = rand(60, 80); s.ballSecurity = rand(70, 90); }
        else if (pos === 'WR') { s.speed = rand(85, 99); s.agility = rand(85, 95); s.catch = rand(75, 95); s.routeRunning = rand(75, 95); s.awareness = rand(60, 85); }
        else if (pos === 'TE') { s.speed = rand(70, 85); s.strength = rand(75, 90); s.catch = rand(70, 90); s.blocking = rand(70, 85); s.routeRunning = rand(65, 85); }
        else if (pos === 'OL') { s.strength = rand(80, 99); s.blocking = rand(80, 95); s.awareness = rand(70, 90); s.speed = rand(40, 60); s.agility = rand(40, 60); }
        else if (pos === 'DL') { s.strength = rand(80, 99); s.passRush = rand(75, 95); s.tackling = rand(75, 95); s.speed = rand(50, 75); s.agility = rand(50, 75); }
        else if (pos === 'LB') { s.strength = rand(70, 90); s.tackling = rand(80, 95); s.passRush = rand(65, 85); s.coverage = rand(60, 85); s.speed = rand(70, 85); s.awareness = rand(70, 90); }
        else if (pos === 'DB') { s.speed = rand(85, 99); s.agility = rand(85, 95); s.coverage = rand(75, 95); s.tackling = rand(60, 80); s.awareness = rand(70, 90); }
        else if (pos === 'K' || pos === 'P') { s.passAccuracy = rand(75, 99); s.passPower = rand(75, 99); s.awareness = rand(70, 90); s.speed = rand(40, 60); }
        return { name: generateName(), af_stats: s };
      })
    });
    const getInitial = (name) => { const initials = name.split(' ').map(w => w[0]).join('').toUpperCase(); return initials.length >= 2 ? initials.substring(0, 3) : name.substring(0, 3).toUpperCase(); };

    if (type === 'Normal') {
      for (let c = 0; c < 2; c++) { for (let d = 0; d < 4; d++) { for (let t = 0; t < 4; t++) {
        const tName = generateTeamName(false); newTeams.push(createTeam(tName, getInitial(tName), ['Conf A', 'Conf B'][c], ['East', 'North', 'South', 'West'][d], c * 16 + d * 4 + t));
      }}}
    } else if (type === 'Simple') {
      for (let c = 0; c < 2; c++) { for (let t = 0; t < 6; t++) {
        const tName = generateTeamName(false); newTeams.push(createTeam(tName, getInitial(tName), ['Conf A', 'Conf B'][c], 'Div 1', c * 6 + t));
      }}
    } else if (type === 'Simple2') {
      for (let t = 0; t < 9; t++) {
        const tName = generateTeamName(false); newTeams.push(createTeam(tName, getInitial(tName), 'Conf A', 'Div 1', t));
      }
    } else if (type === 'Simple3') {
      for (let c = 0; c < 2; c++) {
        const teamCount = c === 0 ? 3 : 4;
        for (let t = 0; t < teamCount; t++) {
          const tName = generateTeamName(false); newTeams.push(createTeam(tName, getInitial(tName), ['Conf A', 'Conf B'][c], 'Div 1', newTeams.length));
        }
      }
    } else {
      for (let i = 0; i < 130; i++) {
        const tName = generateTeamName(true); newTeams.push(createTeam(tName, getInitial(tName), `Conf ${Math.floor(i/13)+1}`, 'Div 1', i));
      }
    }
    setTeams(newTeams); setHasUnsavedChanges(true); setTeamIdx(0); setPlayerIdx(0);
