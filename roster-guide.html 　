            ))}
          </div>

          <div style={{ width: '240px', display: 'flex', flexDirection: 'column', gap: '5px', overflowY: 'auto', border: '1px solid #333', borderRadius: '8px', padding: '10px', backgroundColor: '#111' }}>
            <div style={{ marginBottom: '15px' }}>
              <div style={{ fontSize: '10px', color: '#888', marginBottom: '5px' }}>TEAM NAME & COLOR</div>
              <div style={{ display: 'flex', gap: '5px' }}>
                <input type="text" value={team?.name || ''} onChange={e => updateTeam('name', e.target.value)} style={{ flex: 1, padding: '8px', background: '#000', color: '#0cf', border: '1px solid #555', borderRadius: '4px', fontWeight: 'bold', boxSizing: 'border-box' }} />
                <input type="color" value={team?.color?.home?.main || '#1a5f9a'} onChange={e => updateTeamColor(e.target.value)} style={{ width: '35px', height: '35px', padding: '0', border: 'none', borderRadius: '4px', cursor: 'pointer', backgroundColor: 'transparent' }} />
              </div>
            </div>
            <h4 style={{ margin: '0 0 10px 0', color: '#888', borderBottom: '1px solid #333', paddingBottom: '5px' }}>ROSTER</h4>
            <button onClick={() => setPlayerIdx(-1)} style={{ padding: '10px', textAlign: 'left', backgroundColor: playerIdx === -1 ? '#f90' : '#222', color: playerIdx === -1 ? '#000' : '#fff', border: 'none', borderRadius: '4px', cursor: 'pointer', display: 'flex', justifyContent: 'space-between', fontWeight: 'bold', marginBottom: '5px' }}>
              <span>HEAD COACH</span>
              <span style={{ opacity: 0.7 }}>HC</span>
            </button>
            {team?.lineup.map((p, i) => (
              <button key={i} onClick={() => setPlayerIdx(i)} style={{ padding: '8px 10px', textAlign: 'left', backgroundColor: playerIdx === i ? '#0cf' : 'transparent', color: playerIdx === i ? '#000' : '#fff', border: playerIdx === i ? 'none' : '1px solid #333', borderRadius: '4px', cursor: 'pointer', display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                <span style={{ overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap', flex: 1 }}>{p.name}</span>
                <span style={{ fontSize: '11px', opacity: playerIdx === i ? 0.7 : 0.5, marginLeft: '10px', width: '30px', textAlign: 'right' }}>{p.af_stats?.position || 'N/A'}</span>
              </button>
            ))}
          </div>

          <div style={{ flex: 1, padding: '20px', backgroundColor: '#111', borderRadius: '8px', border: '1px solid #333', overflowY: 'auto' }}>
            {playerIdx === -1 ? (
              <div style={{ display: 'flex', flexDirection: 'column', gap: '15px' }}>
                <div style={{ display: 'flex', alignItems: 'center', gap: '15px', borderBottom: '1px solid #333', paddingBottom: '15px' }}>
                  <div style={{ fontSize: '30px' }}>👔</div>
                  <div style={{ flex: 1 }}>
                    <div style={{ color: '#f90', fontSize: '12px', fontWeight: 'bold' }}>HEAD COACH</div>
                    <input type="text" value={team?.manager?.name || ''} onChange={e => updateManager('name', e.target.value)} style={{ width: '100%', maxWidth: '300px', padding: '10px', background: '#000', color: '#fff', border: '1px solid #555', borderRadius: '4px', fontSize: '16px', fontWeight: 'bold', marginTop: '5px', boxSizing: 'border-box' }} />
                  </div>
                </div>
                <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(200px, 1fr))', gap: '15px' }}>
                  {['inside_run', 'outside_run', 'short_pass', 'deep_pass', 'def_aggressiveness'].map(stat => (
                    <div key={stat} style={{ display: 'flex', flexDirection: 'column', backgroundColor: '#222', padding: '10px', borderRadius: '8px', gap: '8px', boxShadow: 'inset 0 0 10px rgba(0,0,0,0.5)' }}>
                      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                        <span style={{ color: '#aaa', fontSize: '12px' }}>{stat.toUpperCase()}</span>
                        <span style={{ color: '#f90', fontWeight: 'bold', fontFamily: 'monospace', fontSize: '16px' }}>{team?.manager?.[stat] ?? 50}</span>
                      </div>
                      <input type="range" min="0" max="100" value={team?.manager?.[stat] ?? 50} onChange={e => updateManager(stat, e.target.value)} style={{ width: '100%', cursor: 'pointer', accentColor: '#f90' }} />
                    </div>
                  ))}
                </div>
              </div>
            ) : player && (
              <div style={{ display: 'flex', flexDirection: 'column', gap: '15px' }}>
                <div style={{ display: 'flex', alignItems: 'center', gap: '15px', borderBottom: '1px solid #333', paddingBottom: '15px' }}>
                  <div style={{ fontSize: '30px' }}>🏈</div>
                  <div style={{ flex: 1, display: 'flex', flexDirection: 'column', gap: '5px' }}>
                    <div style={{ color: '#0cf', fontSize: '12px', fontWeight: 'bold' }}>PLAYER</div>
                    <div style={{ display: 'flex', gap: '10px', maxWidth: '500px' }}>
                      <input type="text" value={player.name} onChange={e => updatePlayer('name', e.target.value)} style={{ flex: 2, padding: '10px', background: '#000', color: '#fff', border: '1px solid #555', borderRadius: '4px', fontWeight: 'bold', fontSize: '16px', minWidth: 0, boxSizing: 'border-box' }} />
                      <select value={player.af_stats?.position || 'N/A'} onChange={e => updatePlayer('position', e.target.value)} style={{ flex: 1, padding: '10px', background: '#000', color: '#fff', border: '1px solid #555', borderRadius: '4px', fontSize: '16px', minWidth: 0, boxSizing: 'border-box' }}>
                        <option value="QB">QB</option><option value="RB">RB</option><option value="FB">FB</option>
                        <option value="WR">WR</option><option value="TE">TE</option><option value="OL">OL</option>
                        <option value="DL">DL</option><option value="LB">LB</option><option value="DB">DB</option>
                        <option value="K">K</option><option value="P">P</option>
                      </select>
                    </div>
                  </div>
                </div>
                <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(200px, 1fr))', gap: '15px' }}>
                  {['speed', 'strength', 'agility', 'awareness', 'passAccuracy', 'passPower', 'catch', 'routeRunning', 'ballSecurity', 'blocking', 'passRush', 'tackling', 'coverage'].map(stat => (
                    <div key={stat} style={{ display: 'flex', flexDirection: 'column', backgroundColor: '#222', padding: '10px', borderRadius: '8px', gap: '8px', boxShadow: 'inset 0 0 10px rgba(0,0,0,0.5)' }}>
                      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                        <span style={{ color: '#aaa', fontSize: '12px' }}>{stat.toUpperCase()}</span>
                        <span style={{ color: '#0f0', fontWeight: 'bold', fontFamily: 'monospace', fontSize: '16px' }}>{player.af_stats?.[stat] ?? 0}</span>
                      </div>
                      <input type="range" min="0" max="100" value={player.af_stats?.[stat] ?? 0} onChange={e => updatePlayer(stat, e.target.value)} style={{ width: '100%', cursor: 'pointer', accentColor: '#0f0' }} />
                    </div>
                  ))}
                </div>
              </div>
            )}
            </div>
          </div>
          )}

          <div style={{ backgroundColor: '#111', padding: '20px', borderRadius: '8px', border: '1px solid #333', marginTop: '10px' }}>
            <h3 style={{ color: '#0cf', marginTop: 0, borderBottom: '1px dashed #333', paddingBottom: '10px' }}>{tTextEdit('データ出力 (Export)', 'Exportar Datos', 'Data Export')}</h3>
            <div style={{ display: 'flex', flexDirection: isMobile ? 'column' : 'row', gap: '10px', alignItems: isMobile ? 'stretch' : 'center' }}>
              <div style={{ color: '#888', fontSize: '14px', width: isMobile ? '100%' : '100px' }}>{tTextEdit('フォーマット:', 'Formato:', 'Format:')}</div>
              <div style={{ display: 'flex', gap: '10px', flex: 1 }}>
                <select value={exportFormat} onChange={e => setExportFormat(e.target.value)} style={{ width: '100px', padding: '12px', backgroundColor: '#1a1a1a', color: '#fff', border: '1px solid #555', borderRadius: '4px', fontFamily: 'monospace', fontSize: '14px' }}>
                  <option value="txt">TXT</option>
                  <option value="json">JSON</option>
                  <option value="csv">CSV</option>
                </select>
                <button onClick={() => handleExport(teams, exportFormat)} style={{ flex: 1, padding: '12px', backgroundColor: 'rgba(76, 175, 80, 0.1)', color: '#4CAF50', border: '1px solid #4CAF50', borderRadius: '4px', cursor: 'pointer', fontWeight: 'bold', display: 'flex', justifyContent: 'center', alignItems: 'center', gap: '10px', fontSize: '16px' }}>
                  📤 {tTextEdit('ファイル保存 / 共有', 'Guardar / Compartir', 'Save / Share')}
                </button>
              </div>
            </div>
          </div>
        </div>
      )}

      {confirmModal && (
        <div style={{ position: 'fixed', top: 0, left: 0, width: '100%', height: '100%', backgroundColor: 'rgba(0,0,0,0.8)', display: 'flex', justifyContent: 'center', alignItems: 'center', zIndex: 9999 }}>
          <div style={{ backgroundColor: '#222', padding: '20px', borderRadius: '8px', border: '1px solid #0cf', width: '300px', textAlign: 'center' }}>
            <h3 style={{ color: '#0cf', marginTop: 0, letterSpacing: '2px' }}>{tTextEdit('ℹ️ 確認', 'ℹ️ CONFIRMACIÓN', 'ℹ️ CONFIRMATION')}</h3>
            <p style={{ color: '#fff', fontSize: '14px', lineHeight: '1.6', whiteSpace: 'pre-wrap' }}>
              {tTextEdit(`${confirmModal === 'Simple3' ? 'Simple 1' : confirmModal === 'Simple2' ? 'Simple 2' : confirmModal === 'Simple' ? 'Simple 3' : confirmModal === 'Normal' ? 'ノーマル' : 'メガリーグ'} のリーグ構成を生成します。\n${teams && teams.length > 0 ? '現在のデータは全て上書きされます。\n' : ''}よろしいですか？`, `Se generará la liga de tipo ${confirmModal === 'Simple3' ? 'Simple 1' : confirmModal === 'Simple2' ? 'Simple 2' : confirmModal === 'Simple' ? 'Simple 3' : confirmModal === 'Normal' ? 'Normal' : 'Mega'}.\n${teams && teams.length > 0 ? 'Todos los datos actuales serán sobrescritos.\n' : ''}¿Estás seguro?`, `Generate ${confirmModal === 'Simple3' ? 'Simple 1' : confirmModal === 'Simple2' ? 'Simple 2' : confirmModal === 'Simple' ? 'Simple 3' : confirmModal === 'Normal' ? 'Normal' : 'Mega'} league data.\n${teams && teams.length > 0 ? 'All current data will be overwritten.\n' : ''}Are you sure?`)}
            </p>
            <div style={{ display: 'flex', justifyContent: 'space-around', marginTop: '20px' }}>
              <button onClick={() => setConfirmModal(null)} style={{ padding: '10px 20px', backgroundColor: '#555', color: '#fff', border: 'none', borderRadius: '4px', cursor: 'pointer' }}>{tTextEdit('キャンセル', 'CANCELAR', 'CANCEL')}</button>
              <button onClick={confirmGenerateLeague} style={{ padding: '10px 20px', backgroundColor: '#0cf', color: '#000', border: 'none', borderRadius: '4px', cursor: 'pointer', fontWeight: 'bold' }}>{tTextEdit('生成する', 'GENERAR', 'GENERATE')}</button>
            </div>
          </div>
        </div>
      )}

      {alertMessage && (
        <div style={{ position: 'fixed', top: 0, left: 0, width: '100%', height: '100%', backgroundColor: 'rgba(0,0,0,0.8)', display: 'flex', justifyContent: 'center', alignItems: 'center', zIndex: 10000 }}>
          <div style={{ backgroundColor: '#222', padding: '25px', borderRadius: '8px', border: '1px solid #4CAF50', width: '300px', textAlign: 'center' }}>
            <h3 style={{ color: '#4CAF50', marginTop: 0, letterSpacing: '1px' }}>SYSTEM MESSAGE</h3>
            <p style={{ color: '#fff', fontSize: '15px', lineHeight: '1.6' }}>{alertMessage}</p>
            <button onClick={() => setAlertMessage('')} style={{ padding: '10px 40px', backgroundColor: '#4CAF50', color: '#000', border: 'none', borderRadius: '4px', cursor: 'pointer', fontWeight: 'bold', marginTop: '15px', fontSize: '16px' }}>OK</button>
          </div>
        </div>
      )}

      {showImportHelp && (
        <div style={{ position: 'fixed', top: 0, left: 0, width: '100%', height: '100%', backgroundColor: 'rgba(0,0,0,0.85)', display: 'flex', justifyContent: 'center', alignItems: 'center', zIndex: 10000 }}>
          <div style={{ backgroundColor: '#1a1a1a', padding: '25px', borderRadius: '8px', border: '1px solid #0cf', width: '90%', maxWidth: '340px', color: '#fff' }}>
            <h3 style={{ color: '#0cf', marginTop: 0, letterSpacing: '1px', borderBottom: '1px solid #333', paddingBottom: '10px' }}>{isJa ? 'インポートガイド' : 'Import Guide'}</h3>
            <ol style={{ paddingLeft: '20px', fontSize: '14px', lineHeight: '1.6', color: '#ccc', margin: '20px 0' }}>
              <li style={{ marginBottom: '10px' }}>{isJa ? '外部サイト（下記リンク参照）等でロースターのCSVファイルを端末に保存します。' : 'Save a roster CSV file to your device from external sites.'}</li>
              <li style={{ marginBottom: '10px' }}>{isJa ? 'iOSの「ファイル」アプリやAndroidの「ダウンロード」フォルダにあることを確認します。' : 'Ensure it is in your iOS "Files" or Android "Downloads" folder.'}</li>
              <li>{isJa ? '「📥 端末のCSV/JSONファイルを選択」からそのファイルを選ぶか、中身のテキストをコピーして「📋 貼り付け」します。' : 'Use "Select Local File" or copy the text and use "Paste".'}</li>
            </ol>
            <div style={{ marginTop: '20px', textAlign: 'center' }}>
              <button onClick={() => setShowImportHelp(false)} style={{ padding: '10px 40px', backgroundColor: '#333', color: '#fff', border: '1px solid #555', borderRadius: '4px', cursor: 'pointer', fontWeight: 'bold' }}>{isJa ? '閉じる' : 'CLOSE'}</button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
};
